# .env.sample - copy to .env and fill in real values before docker compose up.

# --- Keycloak ---
KEYCLOAK_REALM=icl-realm
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8081
KEYCLOAK_CLIENT_ID=icl-backend
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_PORT=8081

# Token lifespans baked into the realm on import (see realm-export/icl-realm.json.template).
# These control "expires_in" (access token) and "refresh_expires_in" (refresh token) in the
# /auth/login and /auth/refresh responses. Only take effect on a fresh Keycloak container -
# changing them after the realm already exists requires recreating the keycloak container
# (docker compose down -v keycloak && docker compose up -d keycloak) or updating the realm
# via the Keycloak admin console.
KEYCLOAK_ACCESS_TOKEN_LIFESPAN_SECONDS=300
KEYCLOAK_REFRESH_TOKEN_LIFESPAN_SECONDS=1800

# --- Postgres (owned by this service; Keycloak uses its own embedded H2 in dev mode) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=icl_auth
DB_USERNAME=icl_service
DB_PASSWORD=change-me

# --- Server ---
PORT=8080
